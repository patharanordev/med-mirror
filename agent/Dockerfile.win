# Use NVIDIA CUDA Runtime (Includes libcublas, libcudnn for GPU Support)
FROM nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

WORKDIR /app

# Prevent interactive prompts during apt install
ENV DEBIAN_FRONTEND=noninteractive

# Install Python 3.11 and Audio/System Dependencies
# software-properties-common needed for add-apt-repository if python3.11 isn't in default repos (Ubuntu 22.04 has 3.10 default, checking...)
# Ubuntu 22.04 has python3.10 default. We can use 3.10 (it's fine) or install 3.11 via deadsnakes.
# Using default python3 (3.10) is simpler and sufficient for faster-whisper.
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    libsndfile1 \
    ffmpeg \
    && ln -s /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Run the application
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001"]
